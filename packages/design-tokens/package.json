{
	"name": "design-tokens",
	"version": "0.1.0",
	"private": true,
	"description": "One source of truth for design values, projected into per-platform outputs (Tailwind v3 + v4, plain CSS, React Native).",
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		"./css/variables.css": "./dist/css/variables.css",
		"./css/variables.v3.css": "./dist/css/variables.v3.css",
		"./css/theme.v4.css": "./dist/css/theme.v4.css",
		"./tailwind/theme.cjs": "./dist/tailwind/theme.cjs",
		"./native": {
			"types": "./dist/native/index.d.ts",
			"import": "./dist/native/index.js",
			"require": "./dist/native/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "node build.mjs",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"style-dictionary": "^4.3.0"
	}
}
